FROM node:22-bookworm-slim AS build

WORKDIR /app

COPY control-dashboard/package.json control-dashboard/package-lock.json ./
RUN npm ci

COPY control-dashboard/ ./

ARG VITE_BASE_PATH=/
ARG VITE_PI_SERVER_IP=rover.tail9d0237.ts.net
ARG VITE_MQTT_HOST=wss://84f09906a62e42c78c5d9b0555aa71f1.s1.eu.hivemq.cloud:8884/mqtt
ARG VITE_RELAY_BASE_URL=https://jjcloud.tail9d0237.ts.net
ARG VITE_WEBRTC_ICE_MODE
ARG VITE_WEBRTC_SIGNALING_MODE
ARG VITE_VIDEO_STREAM_MODE
ARG VITE_VOICE_DRIVE_DEBUG
ARG VITE_BACKUP_STREAM_URL
ARG VITE_CAMERA_SECRET
ARG VITE_LIDAR_SCAN_URL

ENV VITE_BASE_PATH=${VITE_BASE_PATH}
ENV VITE_PI_SERVER_IP=${VITE_PI_SERVER_IP}
ENV VITE_MQTT_HOST=${VITE_MQTT_HOST}
ENV VITE_RELAY_BASE_URL=${VITE_RELAY_BASE_URL}
ENV VITE_WEBRTC_ICE_MODE=${VITE_WEBRTC_ICE_MODE}
ENV VITE_WEBRTC_SIGNALING_MODE=${VITE_WEBRTC_SIGNALING_MODE}
ENV VITE_VIDEO_STREAM_MODE=${VITE_VIDEO_STREAM_MODE}
ENV VITE_VOICE_DRIVE_DEBUG=${VITE_VOICE_DRIVE_DEBUG}
ENV VITE_BACKUP_STREAM_URL=${VITE_BACKUP_STREAM_URL}
ENV VITE_CAMERA_SECRET=${VITE_CAMERA_SECRET}
ENV VITE_LIDAR_SCAN_URL=${VITE_LIDAR_SCAN_URL}

RUN npm run build

FROM nginx:1.27-alpine

COPY control-dashboard/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 80
