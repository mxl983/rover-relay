# Rover Dashboard – environment variables
# Copy to .env and set values. All VITE_* are exposed to the client bundle.

# Pi server host (no protocol). Example: rover.tail9d0237.ts.net
VITE_PI_SERVER_IP=rover.tail9d0237.ts.net

# MQTT broker URL (WSS). Example: wss://xxx.s1.eu.hivemq.cloud:8884/mqtt
VITE_MQTT_HOST=wss://84f09906a62e42c78c5d9b0555aa71f1.s1.eu.hivemq.cloud:8884/mqtt

# Relay host for backup camera stream + telemetry history APIs.
VITE_RELAY_BASE_URL=https://jjcloud.tail9d0237.ts.net
# Optional explicit backup stream URL override.
# VITE_BACKUP_STREAM_URL=https://jjcloud.tail9d0237.ts.net:8787/api/cams/backup/stream

# Camera API secret – must match server. Prefer setting on server only; if set here it is in the client bundle.
# VITE_CAMERA_SECRET=rover-alpha-99

# Log voice assistant actions and control payloads in the browser console (dev / debugging).
# VITE_VOICE_DRIVE_DEBUG=true

# Voice recognition language (push-to-talk / manual send). Defaults: zh browser -> zh-CN else en-US.
# VITE_VOICE_RECOGNITION_LANG=zh-CN
# Live mode language override (defaults to zh-CN to avoid English-biased live transcription).
# VITE_VOICE_RECOGNITION_LIVE_LANG=zh-CN
