RELAY_PUBLIC_HTTPS_PORT=443
PORT=8787
HOST=0.0.0.0
NODE_ENV=development
SSL_ENABLED=true
SSL_CERT_PATH=./certs/relay.crt
SSL_KEY_PATH=./certs/relay.key
HTTP_REDIRECT_ENABLED=false
HTTP_REDIRECT_PORT=8080

# Comma-separated browser origins for CORS. Browsers only send scheme+host (no path), so
# https://mxl983.github.io covers the GitHub Pages app at https://mxl983.github.io/rover-relay/
# (a full site URL in this list is normalized to its origin).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://mxl983.github.io,https://jjcloud.tail9d0237.ts.net

# Shared secret for POST /api/telemetry/ingest, POST /api/telemetry/client-connection, POST /api/rover/heartbeat
ROVER_API_TOKEN=
REQUEST_LOG_ENABLED=true
MQTT_BOOT_ENABLED=true
MQTT_BOOT_URL=wss://84f09906a62e42c78c5d9b0555aa71f1.s1.eu.hivemq.cloud:8884/mqtt
MQTT_BOOT_USER=
MQTT_BOOT_PASS=
MQTT_BOOT_TOPIC=rover/power/pi
MQTT_BOOT_PAYLOAD_PREFIX=On

TELEMETRY_DB_PATH=./data/relay.db
TELEMETRY_RETENTION_DAYS=14

# ESP32 backup camera (must be reachable from the relay host — often Tailscale IP of the Pi or a hop URL)
BACKUP_CAM_STREAM_URL=http://192.168.1.220:81/stream
BACKUP_CAM_STREAM_AUTH=false

ROVER_HEARTBEAT_STALE_MS=90000
ROVER_BOOT_TOTAL_MS=50000
BATTERY_DRAIN_WINDOW_MS=120000

# Charger LED via USB webcam (ffmpeg); red ≈ charging, green ≈ idle
# List devices: ls -l /dev/video*  (Docker: must match relay `devices:` in docker-compose)
# CHARGING_LED_WEBCAM_DEVICE=/dev/video0
# CHARGING_LED_WEBCAM_TIMEOUT_MS=2500
# CHARGING_LED_WEBCAM_WIDTH=320
# CHARGING_LED_WEBCAM_HEIGHT=240
# Optional: negotiate capture at device (e.g. 320x240), then scale to WIDTH×HEIGHT
# CHARGING_LED_WEBCAM_CAPTURE_SIZE=320x240
# Dedupe identical polls within this window (ms); 0 = always grab fresh frame
# CHARGING_LED_WEBCAM_CACHE_TTL_MS=200
# CHARGING_LED_WEBCAM_INPUT_FORMAT=mjpeg
# Optional until camera is mounted: CHARGING_LED_WEBCAM_STUB=idle | charging | error
# Hue bounds (0–360). If CHARGING min > max, band wraps (e.g. 350–12 for red at 0°/360°):
# CHARGING_LED_CHARGING_HUE_MIN=0
# CHARGING_LED_CHARGING_HUE_MAX=72
# CHARGING_LED_GREEN_HUE_MIN=73
# CHARGING_LED_GREEN_HUE_MAX=165
# Ignore dark/black pixels (max R,G,B below this 0–255) when computing LED hue
# CHARGING_LED_IGNORE_BELOW_RGB_MAX=14
# Legacy alias: CHARGING_LED_YELLOW_HUE_MIN / CHARGING_LED_YELLOW_HUE_MAX

# Control dashboard container (React/Vite app from mxl983/rover/dashboard)
CONTROL_DASHBOARD_PORT=5174
CONTROL_DASHBOARD_BASE_PATH=/mangomate/
CONTROL_DASHBOARD_PI_SERVER_IP=rover.tail9d0237.ts.net
CONTROL_DASHBOARD_MQTT_HOST=wss://84f09906a62e42c78c5d9b0555aa71f1.s1.eu.hivemq.cloud:8884/mqtt
CONTROL_DASHBOARD_RELAY_BASE_URL=https://jjcloud.tail9d0237.ts.net
CONTROL_DASHBOARD_WEBRTC_ICE_MODE=tailnet
CONTROL_DASHBOARD_WEBRTC_SIGNALING_MODE=proxy
CONTROL_DASHBOARD_VIDEO_STREAM_MODE=webrtc
CONTROL_DASHBOARD_VOICE_DRIVE_DEBUG=true
CONTROL_DASHBOARD_BACKUP_STREAM_URL=
CONTROL_DASHBOARD_CAMERA_SECRET=
CONTROL_DASHBOARD_PROXY_ENABLED=true
CONTROL_DASHBOARD_PROXY_BASE_PATH=/mangomate
CONTROL_DASHBOARD_PROXY_TARGET=http://control-dashboard:80
